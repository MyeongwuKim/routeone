{
  "name": "routeone",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:api:test": "pnpm --filter api dev:test",
    "dev:analyzer": "cd apps/image-analyzer && IMAGE_ANALYZER_TOKEN=${IMAGE_ANALYZER_TOKEN:-local-dev-token} .venv/bin/python -m uvicorn src.main:app --host 127.0.0.1 --port 4100",
    "dev:web": "pnpm --filter web dev",
    "analyzer:check": "PYTHONPYCACHEPREFIX=/private/tmp/routeone-pycache apps/image-analyzer/.venv/bin/python -m py_compile apps/image-analyzer/src/__init__.py apps/image-analyzer/src/analyzer.py apps/image-analyzer/src/main.py",
    "build": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "preview:web": "pnpm --filter web preview",
    "native:start": "pnpm --filter native start",
    "native:start:dev-client": "pnpm --filter native start:dev-client",
    "native:start:go": "pnpm --filter native start:go",
    "native:start:bundle": "pnpm --filter native start:bundle",
    "native:android": "pnpm --filter native android",
    "native:ios": "pnpm --filter native ios",
    "native:typecheck": "pnpm --filter native typecheck",
    "native:sync:web": "pnpm --filter native sync:web",
    "native:build:webview": "pnpm --filter native build:webview"
  }
}
