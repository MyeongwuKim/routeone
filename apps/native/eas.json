{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "dev",
        "EXPO_PUBLIC_APP_VARIANT": "dev"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "dev",
        "EXPO_PUBLIC_APP_VARIANT": "dev"
      },
      "ios": {
        "simulator": false
      }
    },
    "testflight-dev": {
      "autoIncrement": true,
      "distribution": "store",
      "env": {
        "APP_VARIANT": "dev",
        "EXPO_PUBLIC_APP_VARIANT": "dev"
      },
      "ios": {
        "image": "latest"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "env": {
        "APP_VARIANT": "prod",
        "EXPO_PUBLIC_APP_VARIANT": "prod"
      },
      "ios": {
        "image": "latest"
      }
    }
  },
  "submit": {
    "testflight-dev": {
      "ios": {}
    },
    "production": {
      "ios": {}
    }
  }
}
